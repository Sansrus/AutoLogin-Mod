{
  "schemaVersion": 1,
  "id": "autologin_mod",
  "version": "${version}",
  "name": "AutoLogin Mod",
  "description": "Мод для автоматического ввода пароля",
  "authors": ["Sansrus"],
  "contact": {
    "homepage": "https://modrinth.com/user/Sansrus",
    "sources": "https://github.com/Sansrus/AutoLogin-Mod",
    "issues": "https://github.com/Sansrus/AutoLogin-Mod/issues"
  },
  "license": "All-Rights-Reserved",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.example.s.client1_21.autologin_modClient"
    ],
    "main": [
      "org.example.s.autologin_mod"
    ],
    "modmenu": ["org.example.s.client1_21.ModMenuIntegration"]
  },
  "mixins": [
    {
      "config": "autologin_mod.client.mixins.json",
      "environment": "client"
    }
